      "brief_keywords": ["会议议定", "纪要如下", "会议认为", "会议要求", "会议强调", "参会", "主持人"],
      "audience_keywords": ["参会单位", "责任部门", "督办部门"],
      "style_keywords": ["庄重规范", "简洁有力"],
      "rationale": ["会议纪要用于固定会议形成的结论、责任和时限，不是原始记录。", "如果输入材料明显来自会议研究或专题调度，优先考虑纪要。"]
    },
    {
      "name": "工作方案",
      "priority": "P1",
      "direction": "内部执行文",
      "purpose": "明确目标、任务、步骤、责任、保障",
      "template": "templates/工作方案-template.md",
      "scene_keywords": ["对下部署", "迎检迎查", "专项调度", "实施", "推进", "专项整治", "活动组织"],
      "brief_keywords": ["制定本方案", "工作方案", "实施方案", "主要任务", "实施步骤", "责任分工", "保障措施"],
      "audience_keywords": ["专班", "执行部门", "牵头单位", "配合单位"],
      "style_keywords": ["部署型", "简洁有力", "庄重规范"],
      "rationale": ["工作方案重在把怎么干、分几步、谁负责、如何保障写清。", "若文本需要可执行结构而不只是发文告知，应优先考虑工作方案。"]
    },
    {
      "name": "工作总结",
      "priority": "P2",
      "direction": "内部复盘/上报",
      "purpose": "系统回顾、提炼经验、查找不足、提出改进方向",
      "template": "templates/工作总结-template.md",
      "scene_keywords": ["存档备查", "阶段复盘", "年度", "季度", "半年", "总结"],
      "brief_keywords": ["总结如下", "经验做法", "存在问题", "下一步打算", "阶段性总结", "年度工作总结"],
      "audience_keywords": ["管理层", "上级", "考核", "述职"],
      "style_keywords": ["成效总结型", "问题导向型", "汇报型"],
      "rationale": ["工作总结比一般报告更强调复盘、经验沉淀和问题归纳。", "如果重点是回顾一段时期工作并提炼经验教训，更适合总结。"]
    },
    {
      "name": "简报/信息",
      "priority": "P2",
      "direction": "内部快报",
      "purpose": "短、快、准地报送动态、亮点、进展、风险",
      "template": "templates/新闻通稿-template.md",
      "scene_keywords": ["动态", "快报", "专报", "专班", "内部流转", "迎检迎查"],
      "brief_keywords": ["工作简报", "动态信息", "专报", "快报", "情况信息", "现将有关情况简报如下"],
      "audience_keywords": ["领导", "专班", "管理层"],
      "style_keywords": ["简洁有力", "汇报型"],
      "rationale": ["简报/信息强调时效和信息密度，适合动态报送而非完整正式报告。", "如果诉求是短、快、准地同步情况，应优先考虑简报/信息。"]
    }
  ]
}
