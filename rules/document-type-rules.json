      "style_keywords": ["庄重规范", "稳妥克制"],
      "rationale": ["请示用于向有审批权的主体请求批准、指示或支持。", "若目标是拿到批复结果，而非单纯汇报，应优先归入请示。"]
    },
    {
      "name": "报告",
      "priority": "P1",
      "direction": "上行",
      "purpose": "汇报情况、进展、整改、结果",
      "template": "templates/报告-template.md",
