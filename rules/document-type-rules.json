    "工作方案": ["工作方案", "方案", "实施方案", "专项方案", "活动方案"],
    "汇报材料": ["汇报材料", "汇报稿", "专题汇报", "情况汇报"],
    "领导讲话稿": ["领导讲话稿", "讲话稿", "领导发言稿"],
    "会议纪要": ["会议纪要", "纪要", "专题会议纪要", "调度会纪要"],
    "函": ["函", "复函", "商洽函", "征求意见函", "协助函"],
    "通报": ["通报", "情况通报", "督查通报"],
