    "通报": ["通知", "报告", "简报/信息"],
    "提纲": ["报告", "工作方案"]
  },
  "document_types": [
    {
      "name": "通知",
      "priority": "P1",
      "direction": "下行/内部部署",
      "purpose": "部署、传达、安排、报送、印发",
      "template": "templates/通知-template.md",
      "scene_keywords": ["对下部署", "部署", "安排", "报送", "下发", "印发", "会议通知", "培训通知", "贯彻落实"],
      "brief_keywords": ["通知如下", "请各单位", "抓好落实", "按时报送", "贯彻落实", "印发", "召开", "报送材料", "有关事项"],
      "audience_keywords": ["各单位", "各部门", "各子公司", "各项目部", "下属单位", "所属企业", "各处室"],
      "style_keywords": ["部署型", "简洁有力", "庄重规范"],
      "rationale": ["更适合有组织要求关系的下发、部署和告知事项。", "通知重在把要求、对象、时限和报送方式发下去。"]
    },
    {
      "name": "请示",
      "priority": "P1",
      "direction": "上行",
      "purpose": "请求批准、批示、支持、协调",
      "template": "templates/请示-template.md",
