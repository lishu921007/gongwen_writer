      "audience_keywords": ["上级", "省政府", "主管部门", "领导", "办公厅", "条线部门"],
      "style_keywords": ["汇报型", "稳妥克制", "问题导向型", "成效总结型"],
      "rationale": ["报告适合向上级或管理层汇报事实、进展、结果和问题。", "核心是报情况，不以获得批复为主要目的。"]
    },
    {
      "name": "函",
      "priority": "P1",
      "direction": "平行",
      "purpose": "商洽、征求意见、协助、复函",
      "template": "templates/函-template.md",
      "scene_keywords": ["对外协调", "商洽", "征求意见", "协助", "复函", "平行沟通"],
      "brief_keywords": ["特函", "函请", "商请", "征求意见", "请予支持", "请函复", "复函如下", "协助提供"],
      "audience_keywords": ["你单位", "贵单位", "兄弟单位", "协作单位", "外部单位", "平行部门"],
      "style_keywords": ["庄重规范", "稳妥克制"],
      "rationale": ["函用于平行或不相隶属单位之间正式商洽、询复和协助。", "如果不宜使用命令口吻、但又需要正式行文，通常更适合函。"]
    },
    {
      "name": "会议纪要",
      "priority": "P1",
      "direction": "内部过程文",
      "purpose": "固化会议议定事项、责任分工、会议结论",
      "template": "templates/会议纪要-template.md",
